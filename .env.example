# ─────────────────────────────────────────────────────────────
#  MediVault — Environment Variables
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# ── Frontend (Vite build-time variables) ─────────────────────
# Leave empty to use relative paths (recommended for Vercel —
# frontend and API are served from the same domain via rewrites).
VITE_API_BASE_URL=

# Set to 'true' to run entirely in-browser with localStorage mock
# (no backend required). Leave 'false' in production.
VITE_ENABLE_MOCK_AUTH=false

# ── PostgreSQL database ───────────────────────────────────────
# Required. Obtain from your database provider (e.g. Neon, Supabase, Railway).
DATABASE_URL=postgresql://user:password@host:5432/medivault

# ── Authentication token signing ─────────────────────────────
# Required. Any long random string — used to sign bearer tokens.
SESSION_SECRET=replace-with-a-long-random-secret

# ── Appwrite file storage ─────────────────────────────────────
# Server-side variables (NOT prefixed with VITE_).
# Create a project at https://cloud.appwrite.io and generate an API key.
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_API_KEY=your-appwrite-api-key
APPWRITE_BUCKET_ID=medivault-documents

# ── Google Generative AI (Gemini) ─────────────────────────────
# Required for AI document summarisation feature.
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── CORS (optional) ───────────────────────────────────────────
# Comma-separated list of additional allowed origins for the API.
# On Vercel, the frontend and API share the same domain via rewrites,
# so CORS is not required. Add origins here only if you call the API
# from a separate domain (e.g. a mobile app or external service).
ALLOWED_ORIGINS=

# ── Local development only ────────────────────────────────────
# Port and host for the Express API server (not used on Vercel).
API_PORT=3001
API_HOST=0.0.0.0
